<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Renson Chat Room</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<style>
body {
    margin: 0;
    background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);
    font-family: Arial, sans-serif;
    color: white;
    text-align: center;
}

/* HEADER */
.header {
    padding: 15px;
    font-size: 22px;
    font-weight: bold;
    background: rgba(0,0,0,0.4);
    backdrop-filter: blur(10px);
}

/* CHAT CONTAINER */
.chat-container {
    display: flex;
    justify-content: center;
    margin-top: 20px;
}

/* RESPONSIVE CHAT */
.chat-box {
    width: 90%;
    max-width: 800px;
    border-radius: 15px;
    overflow: hidden;
    box-shadow: 0 0 20px rgba(0,0,0,0.5);
}

/* FOOTER */
.footer {
    margin-top: 20px;
    font-size: 12px;
    opacity: 0.7;
}

/* MOBILE FIX */
@media (max-width: 600px) {
    .header {
        font-size: 18px;
    }
}
</style>

</head>

<body>

<div class="header">
💬 Renson EcoFarm Chat Room
</div>

<div class="chat-container">
    <div class="chat-box">

        <!-- CHATANGO EMBED -->
        <script id="cid0020000438633100540" data-cfasync="false" async 
        src="//st.chatango.com/js/gz/emb.js"
        style="width: 100%; height: 500px;">
        {
            "handle":"rensonchatroom",
            "arch":"js",
            "styles":{
                "a":"0084EF",
                "b":100,
                "c":"FFFFFF",
                "d":"FFFFFF",
                "k":"0084EF",
                "l":"0084EF",
                "m":"0084EF",
                "n":"FFFFFF",
                "p":"10",
                "q":"0084EF",
                "r":100,
                "fwtickm":1
            }
        }
        </script>

    </div>
</div>

<div class="footer">
© 2026 Renson EcoFarm • Free WiFi Chat
</div>

</body>
</html>
